# Server
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://contractual.pro

# Database (MySQL)
# DATABASE_URL=mysql://user:password@localhost:3306/dbname
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=freelancer_platform

# JWT Authentication
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Payment Gateway (Razorpay)
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=contractual
CLOUDINARY_URL=

# Production Security
TRUST_PROXY=1
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REGISTER_MAX=5
