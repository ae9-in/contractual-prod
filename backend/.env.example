# Server
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-app.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# Database (PostgreSQL — Render provides DATABASE_URL in the dashboard)
# After any credential leak, rotate the DB password in Render and update this value only in the host UI, never in git.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: split config instead of DATABASE_URL (local dev)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=contractual_dev

# Optional: set to 0 to disable SSL to local Postgres; 1 forces SSL. Otherwise SSL follows DATABASE_URL / production.
# DATABASE_SSL=

# Database pool and timeout tuning (Render paid tier friendly defaults)
DB_POOL_SIZE=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=6000

# Auth user cache (JWT -> user row) TTL
AUTH_USER_CACHE_TTL_MS=30000

# API response cache cap
RESPONSE_CACHE_MAX=500

# JWT Authentication
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Payment Gateway (Razorpay)
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=contractual
CLOUDINARY_URL=

# SMTP (required for password reset OTP emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Production Security
TRUST_PROXY=1
RATE_LIMIT_LOGIN_MAX=30
RATE_LIMIT_REGISTER_MAX=10
ALLOW_DB_MOCK_FALLBACK=false
